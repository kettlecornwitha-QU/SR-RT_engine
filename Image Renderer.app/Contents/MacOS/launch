#!/bin/zsh
set -euo pipefail
cd "/Users/lukewalker/dev/SR-RT_engine"
python_bin=""
for cand in   "$HOME/.rye/shims/python3"   "/opt/homebrew/bin/python3"   "/usr/local/bin/python3"   "/usr/bin/python3"; do
  if [[ -x "$cand" ]]; then
    python_bin="$cand"
    break
  fi
done
if [[ -z "$python_bin" ]]; then
  echo "No python3 interpreter found." >>/tmp/sr_rt_image_gui.log
  exit 127
fi
exec "$python_bin" tools/gui/raytracer_gui.py >>/tmp/sr_rt_image_gui.log 2>&1
