{
  "preset_schema_version": 2,
  "options_schema_version": 1,
  "scene_base": "row_scatter",
  "scene_name": "row_scatter",
  "palette": "balanced",
  "fps": "30",
  "total_frames": "int(2*fps*halfway)",
  "definitions": [
    "start = 76",
    "end = -150",
    "distance = abs(end - start)",
    "halfway = arcosh(distance/2 + 1)"
  ],
  "camera_location": {
    "rows": [
      {
        "fields": {
          "x": "0",
          "y": "1.2",
          "z": "start - cosh(time) - 1"
        },
        "range_text": "int(fps*halfway)"
      },
      {
        "fields": {
          "x": "0",
          "y": "1.2",
          "z": "cosh(time - 2*halfway) - 1 + start - distance"
        },
        "range_text": ""
      }
    ]
  },
  "camera_velocity": {
    "rows": [
      {
        "fields": {
          "x": "0",
          "y": "0",
          "z": "-tanh(time)"
        },
        "range_text": "int(fps*halfway)"
      },
      {
        "fields": {
          "x": "0",
          "y": "0",
          "z": "tanh(time - 2*halfway)"
        },
        "range_text": ""
      }
    ]
  },
  "camera_orientation": {
    "rows": [
      {
        "fields": {
          "pitch": "0",
          "yaw": "0"
        },
        "range_text": ""
      }
    ]
  },
  "settings": {
    "width": 1920,
    "height": 1080,
    "spp": 64,
    "max_depth": 5,
    "adaptive": true,
    "adaptive_threshold": "0.01",
    "denoise": true,
    "lighting_preset": "cornell-ceiling-plus-key",
    "keep_frames": false
  },
  "preset_name": "Hyperbolic"
}